{
  "name": "openclaw-hud",
  "version": "1.0.0",
  "private": true,
  "description": "OpenClaw HUD Dashboard for local runtime visibility.",
  "homepage": "https://github.com/treygoff24/openclaw-hud#readme",
  "bugs": {
    "url": "https://github.com/treygoff24/openclaw-hud/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/treygoff24/openclaw-hud.git"
  },
  "files": [
    "server.js",
    "lib/",
    "routes/",
    "public/",
    "ws/",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    "SECURITY.md",
    "SUPPORT.md"
  ],
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "fmt": "oxfmt . --ignore-path .oxfmtignore --write",
    "fmt:check": "oxfmt . --ignore-path .oxfmtignore --check",
    "lint": "oxlint . --ignore-path .oxlintignore --deny-warnings -A no-unused-vars -A no-control-regex -A no-useless-escape -A unicorn/no-useless-fallback-in-spread",
    "lint:type-aware": "oxlint . --ignore-path .oxlintignore --type-aware --tsconfig tsconfig.oxlint.json -A no-unused-vars -A no-control-regex -A no-useless-escape -A unicorn/no-useless-fallback-in-spread",
    "quality": "npm run fmt:check && npm run lint && npm run test:coverage && npm run bundle:analyze && npm run specgate:check",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "test:e2e": "npx playwright test",
    "test:e2e:ui": "npx playwright test --ui",
    "vendor:sync": "node scripts/vendor-sync.js",
    "bundle:analyze": "node scripts/bundle-analyze.js",
    "specgate:check": "specgate check",
    "specgate:validate": "specgate validate"
  },
  "dependencies": {
    "express": "5.2.1",
    "json5": "2.2.3",
    "ws": "8.19.0"
  },
  "devDependencies": {
    "@playwright/test": "1.58.2",
    "@vitest/coverage-istanbul": "4.0.18",
    "@vitest/coverage-v8": "4.0.18",
    "jsdom": "28.1.0",
    "memfs": "4.56.10",
    "oxfmt": "0.36.0",
    "oxlint": "1.51.0",
    "oxlint-tsgolint": "0.15.0",
    "supertest": "7.2.2",
    "vitest": "4.0.18"
  },
  "engines": {
    "node": ">=20",
    "npm": ">=10"
  }
}

  },
  "dependencies": {
    "express": "4.22.1",
    "json5": "2.2.3",
    "ws": "8.18.1"
  },
  "devDependencies": {
    "@playwright/test": "1.58.2",
    "@vitest/coverage-istanbul": "4.0.18",
    "@vitest/coverage-v8": "4.0.18",
    "jsdom": "28.1.0",
    "memfs": "4.56.10",
    "supertest": "7.2.2",
    "vitest": "4.0.18"
  }
}

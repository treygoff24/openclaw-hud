{
  "name": "openclaw-hud-kimi",
  "version": "1.0.0",
  "description": "OpenClaw HUD Dashboard — Cyberpunk Command Center by Kimi K2.5",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",

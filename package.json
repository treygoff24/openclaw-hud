{
  "name": "openclaw-hud-kimi",
  "version": "1.0.0",
  "description": "OpenClaw HUD Dashboard — Cyberpunk Command Center by Kimi K2.5",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "fmt": "oxfmt . --ignore-path .oxfmtignore --write",
    "fmt:check": "oxfmt . --ignore-path .oxfmtignore --check",
    "lint": "oxlint . --ignore-path .oxlintignore --deny-warnings -A no-unused-vars -A no-control-regex -A no-useless-escape -A unicorn/no-useless-fallback-in-spread",
    "lint:type-aware": "oxlint . --ignore-path .oxlintignore --type-aware --tsconfig tsconfig.oxlint.json --deny-warnings -A no-unused-vars -A no-control-regex -A no-useless-escape -A unicorn/no-useless-fallback-in-spread",
    "quality": "npm run fmt:check && npm run lint && npm run test:coverage && npm run bundle:analyze",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "test:e2e": "npx playwright test",
    "test:e2e:ui": "npx playwright test --ui",
    "vendor:sync": "node scripts/vendor-sync.js",
    "bundle:analyze": "node scripts/bundle-analyze.js"
  },
  "dependencies": {
    "express": "4.22.1",
    "json5": "2.2.3",
    "ws": "8.18.1"
  },
  "devDependencies": {
    "@playwright/test": "1.58.2",
    "@vitest/coverage-istanbul": "4.0.18",
    "@vitest/coverage-v8": "4.0.18",
    "jsdom": "28.1.0",
    "memfs": "4.56.10",
    "oxfmt": "0.35.0",
    "oxlint": "1.50.0",
    "oxlint-tsgolint": "0.15.0",
    "supertest": "7.2.2",
    "vitest": "4.0.18"
  }
}
